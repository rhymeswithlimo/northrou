# Northrou's public coordination server: the coordinator (WebRTC signaling) with
# Caddy terminating TLS in front of it, at coord.northrou.sh.
# See docs/deploy-coordination.md.
#
# Copy this to deploy.yml, then:
#   docker compose -f deploy.yml up -d --build
#
# There are no secrets here any more (no OAuth broker, no mail relay), so
# deploy.yml is essentially the same as this file. It is still gitignored.

services:
  # Caddy terminates TLS for coord.northrou.sh and proxies the coordinator. The
  # web client is hosted separately on Cloudflare Pages (see
  # .github/workflows/deploy-web.yml), so Caddy serves no static files here.
  caddy:
    image: caddy:2
    restart: unless-stopped
    ports: ["80:80", "443:443"]
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
    depends_on: [coordinator]

  coordinator:
    build: { context: ., dockerfile: coordination/Dockerfile }
    restart: unless-stopped
    environment:
      COORD_ADDR: ":9000"

volumes:
  caddy_data:
