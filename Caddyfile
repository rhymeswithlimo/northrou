# Northrou's coordination stack. Caddy terminates TLS (automatic Let's Encrypt)
# and routes by path, since the coordinator and relay never overlap:
#   coordinator: /ws, /oauth/*, /healthz, /stats  (and the catch-all)
#   relay:       /v1/pin/send  (and its own /healthz, not reachable from here)
#
# The web client is NOT served here: it is hosted on Cloudflare Pages at
# app.northrou.sh (built from GitHub on release; see .github/workflows/
# deploy-web.yml). Coordination lives at coord.northrou.sh so the two don't
# collide on one hostname. See docs/deploy-coordination.md.

coord.northrou.sh {
	# Behind Cloudflare (coord is proxied): serve the Cloudflare Origin
	# certificate so the Cloudflare<->origin leg validates under "Full (strict)".
	# Caddy's automatic Let's Encrypt is intentionally not used here - it can't
	# renew behind the proxy. Cert/key are mounted by deploy.yml. A deployment
	# NOT fronted by Cloudflare should drop this line to get automatic HTTPS back.
	tls /etc/caddy/origin-cert.pem /etc/caddy/origin-key.pem

	handle /v1/* {
		reverse_proxy relay:9100
	}
	handle {
		reverse_proxy coordinator:9000
	}
}
