# Build output
/dist/
/bin/
*.exe

# Release builder: maintainer-only local tool (signing identities, mobile
# toolchains), not distributed. release/ is its generated per-version output.
/scripts/release.sh
/release/

# Coordination deployment (see docs/configuration.md, "Deploying the
# coordination server"). deploy.yml.example is the tracked template;
# deploy.yml is the box's real copy.
/deploy.yml

# Must stay anchored: unanchored, these matched any path segment with those
# names and swallowed the cmd/ dirs named after the binaries they build
# (backend/cmd/northrou, coordination/cmd/coordinator), so a fresh clone
# couldn't build the server. They also hid the Android plugin's Java package,
# .../sh/northrou/native/.
/northrou
/coordinator
# `go build` inside coordination/ drops its binary beside the source.
/coordination/coordinator

# Local dev data / config
*.db
*.db-shm
*.db-wal
/data/
*.local.toml

# OS cruft
.DS_Store

# Xcode: user-specific state and build artifacts, neither shared
xcuserdata/
*.xcuserstate
frontend/swift/**/build/
frontend/swift/**/DerivedData/
*.xcscmblueprint
*.xccheckout

# Managed runtime downloads (ffmpeg, tesseract)
/backend/internal/ffmpeg/testdata/bin/

# Editor
.idea/
.vscode/

# Claude Code instructions: maintainer-local, not part of the distributed repo
CLAUDE.md
.claude/

# Photoshop files
*.psd

# Rust build output, wherever it appears (src-tauri, plugins, future crates)
target/
# Tauri's generated platform projects: regenerated, never edited by hand
/frontend/src-tauri/gen/
# Same idea per plugin's Android module: .tauri/ is Tauri's generated vendor
# cache, build/ is Gradle output. build.gradle.kts, the manifest, and proguard
# rules alongside these ARE hand-written and tracked.
/frontend/plugins/*/android/.tauri/
/frontend/plugins/*/android/build/

# Client build output, generated by `make frontend` and staged into
# internal/web/assets for go:embed. Never committed - a diff full of hashed
# bundles helps nobody. .gitkeep is tracked so `go build` still works in a
# fresh clone that hasn't run the build.
/frontend/dist/
node_modules/
/backend/internal/web/assets/*
!/backend/internal/web/assets/.gitkeep
