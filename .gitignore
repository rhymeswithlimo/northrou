# Temporary:
README.md

# Build output
/dist/
/bin/
*.exe

# Release tooling and output. The release builder is the maintainer's local
# tool (signing identities, mobile toolchains) and is not distributed; the
# release/ tree it fills with per-version artifacts is generated, never tracked.
/scripts/release.sh
/release/

# Coordination stack deployment secrets (see docs/deploy-coordination.md).
# deploy.yml.example is the tracked template; deploy.yml is the box's real copy
# with live OAuth/SMTP credentials and must never be committed.
/deploy.yml
/oauth-signing.pem
*.p8
# Anchored, and they must stay that way. Unanchored, these matched any path
# segment with those names and silently swallowed the cmd/ directories named
# after the binaries they build: backend/cmd/northrou/main.go and
# coordination/cmd/coordinator/main.go were never committed at all, so a fresh
# clone could not build the server. They also hid the Android plugin, whose Java
# package is .../sh/northrou/native/.
/northrou
/coordinator
/relay
# `go build` inside coordination/ drops its binaries beside the source.
/coordination/coordinator
/coordination/relay

# Local dev data / config
*.db
*.db-shm
*.db-wal
/data/
*.local.toml

# OS cruft
.DS_Store

# Xcode user-specific state (not shared)
xcuserdata/
*.xcuserstate
# Xcode build artifacts
frontend/swift/**/build/
frontend/swift/**/DerivedData/
*.xcscmblueprint
*.xccheckout

# Managed runtime downloads (ffmpeg, tesseract)
/backend/internal/ffmpeg/testdata/bin/

# Editor
.idea/
.vscode/

CLAUDE.md
# Rust build output, wherever it appears (src-tauri, plugins, future crates).
target/
# Tauri's generated platform projects: regenerated, never edited by hand.
/frontend/src-tauri/gen/
# Same idea for a plugin's own Android module: .tauri/ is Tauri's generated
# vendor cache, build/ is Gradle output. build.gradle.kts, the manifest, and
# proguard rules alongside these ARE hand-written and tracked.
/frontend/plugins/*/android/.tauri/
/frontend/plugins/*/android/build/

# Client build output. Generated by `make frontend`: staged into
# internal/web/assets for go:embed and never committed, since a diff full of
# hashed bundles helps nobody. .gitkeep is tracked so `go build` still works in
# a fresh clone that hasn't run the build.
/frontend/dist/
node_modules/
/backend/internal/web/assets/*
!/backend/internal/web/assets/.gitkeep
