{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "What the web layer is allowed to ask the shell to do.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://*:*"
        },
        {
          "url": "https://*:*"
        }
      ]
    },
    "northrou-native:default"
  ]
}